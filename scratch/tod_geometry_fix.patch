diff --git a/goalc/build_level/common/gltf_mesh_extract.cpp b/goalc/build_level/common/gltf_mesh_extract.cpp
--- a/goalc/build_level/common/gltf_mesh_extract.cpp
+++ b/goalc/build_level/common/gltf_mesh_extract.cpp
@@ -4,9 +4,54 @@
 #include "gltf_mesh_extract.h"
 #include "color_quantization.h"
 
+#include <array>
+#include <vector>
+
 namespace gltf_mesh_extract {
 
+static const std::array<std::string, 8> kTodColorAttrs = {
+    "COLOR_0", "COLOR_1", "COLOR_2", "COLOR_3",
+    "COLOR_4", "COLOR_5", "COLOR_6", "COLOR_7"};
+
+// Build per-slot color palettes from raw per-vertex slot colors and a shared quantization.
+// quantized.vtx_to_color maps each vertex to its palette bucket (derived from NOON).
+// For each slot, average that slot's raw vertex colors within each bucket.
+static void build_slot_palettes(
+    const std::array<std::vector<math::Vector<u8, 4>>, 8>& raw_slot_colors,
+    const QuantizedColors& quantized,
+    std::array<std::vector<math::Vector<u8, 4>>, 8>& out_palettes) {
+  const size_t n_entries = quantized.final_colors.size();
+  const size_t n_verts = quantized.vtx_to_color.size();
+  for (int s = 0; s < 8; s++) {
+    const auto& raw = raw_slot_colors[s];
+    if (raw.empty()) continue;
+    ASSERT(raw.size() == n_verts);
+    out_palettes[s].assign(n_entries, math::Vector<u8, 4>(0, 0, 0, 0));
+    std::vector<u32> counts(n_entries, 0);
+    std::vector<std::array<u32, 4>> accum(n_entries, std::array<u32, 4>{0, 0, 0, 0});
+    for (size_t v = 0; v < n_verts; v++) {
+      u32 ci = quantized.vtx_to_color[v];
+      for (int ch = 0; ch < 4; ch++) accum[ci][ch] += raw[v][ch];
+      counts[ci]++;
+    }
+    for (size_t ci = 0; ci < n_entries; ci++) {
+      u32 n = counts[ci] ? counts[ci] : 1;
+      for (int ch = 0; ch < 4; ch++)
+        out_palettes[s][ci][ch] = (u8)(accum[ci][ch] / n);
+    }
+  }
+}
+
+// Collect all 8 TOD color slots from one primitive into the running totals.
+static void collect_tod_colors(
+    const tinygltf::Model& model,
+    const std::map<std::string, int>& attributes,
+    const std::vector<math::Vector<u8, 4>>& color_0,
+    std::array<std::vector<math::Vector<u8, 4>>, 8>& all_slot_colors) {
+  const u32 n = (u32)color_0.size();
+  all_slot_colors[0].insert(all_slot_colors[0].end(), color_0.begin(), color_0.end());
+  for (int s = 1; s < 8; s++) {
+    auto c = gltf_util::gltf_read_color_attr(model, attributes, kTodColorAttrs[s], n);
+    if (!c.empty())
+      all_slot_colors[s].insert(all_slot_colors[s].end(), c.begin(), c.end());
+  }
+}
+

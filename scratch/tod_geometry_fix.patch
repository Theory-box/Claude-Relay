Adds multi-slot time-of-day vertex color support to the jak1 custom level builder.

The builder previously read only COLOR_0 from the GLB and duplicated it into all 8
PackedTimeOfDay palette slots, making geometry lighting static regardless of time of day.

With this patch it reads COLOR_0 through COLOR_7 when present, one per TOD slot:
  COLOR_0 = _SUNRISE   COLOR_1 = _MORNING   COLOR_2 = _NOON    COLOR_3 = _AFTERNOON
  COLOR_4 = _SUNSET    COLOR_5 = _TWILIGHT  COLOR_6 = _EVENING COLOR_7 = _GREENSUN

Blender export: use the gltf2_blender_extract.py plugin from custom_assets/blender_plugins/
to export all color_attributes as numbered COLOR_N streams in slot order.

Quantization uses COLOR_2 (_NOON) as the base for the shared vertex->palette-entry
mapping, then re-averages each other slot's raw colors within those same buckets.
Levels with only COLOR_0 (no multi-slot TOD baking) behave identically to before.

Apply with:  git apply tod_geometry_fix.patch
Undo with:   git apply -R tod_geometry_fix.patch
Then:        cmake --build build --target goalc -j$(nproc)

diff --git a/common/util/gltf_util.h b/common/util/gltf_util.h
--- a/common/util/gltf_util.h
+++ b/common/util/gltf_util.h
@@ -178,6 +178,17 @@ tfrag3::PackedTimeOfDay pack_time_of_day(const std::vector<math::Vector<u8, 4>>& color_palette);
 
+// Pack 8 per-slot palettes into a PackedTimeOfDay.
+// Slot order: SUNRISE(0) MORNING(1) NOON(2) AFTERNOON(3) SUNSET(4) TWILIGHT(5) EVENING(6) GREENSUN(7).
+// Empty slots fall back to slot 2 (NOON), or slot 0 if slot 2 is also empty.
+tfrag3::PackedTimeOfDay pack_time_of_day_8(
+    const std::array<std::vector<math::Vector<u8, 4>>, 8>& palettes);
+
+// Read a named vertex color attribute (e.g. "COLOR_3") from a GLTF primitive's attribute map.
+// Returns empty vector if absent or vertex count doesn't match expected_count.
+std::vector<math::Vector<u8, 4>> gltf_read_color_attr(
+    const tinygltf::Model& model,
+    const std::map<std::string, int>& attributes,
+    const std::string& attr_name,
+    u32 expected_count);
+
 struct MercExtractData {

diff --git a/common/util/gltf_util.cpp b/common/util/gltf_util.cpp
--- a/common/util/gltf_util.cpp
+++ b/common/util/gltf_util.cpp
@@ -770,6 +770,67 @@ tfrag3::PackedTimeOfDay pack_time_of_day(const std::vector<math::Vector<u8, 4>>& color_palette) {
   return colors;
 }
 
+tfrag3::PackedTimeOfDay pack_time_of_day_8(
+    const std::array<std::vector<math::Vector<u8, 4>>, 8>& palettes) {
+  const auto& base = palettes[2].empty() ? palettes[0] : palettes[2];
+  ASSERT_MSG(!base.empty(), "pack_time_of_day_8: slots 0 and 2 both empty");
+  tfrag3::PackedTimeOfDay colors;
+  colors.color_count = (base.size() + 3) & (~3);
+  colors.data.resize(colors.color_count * 8 * 4);
+  for (u32 color_index = 0; color_index < base.size(); color_index++) {
+    for (u32 palette = 0; palette < 8; palette++) {
+      const auto& src = palettes[palette].empty() ? base : palettes[palette];
+      for (u32 channel = 0; channel < 4; channel++) {
+        colors.read(color_index, palette, channel) = src[color_index][channel];
+      }
+    }
+  }
+  return colors;
+}
+
+std::vector<math::Vector<u8, 4>> gltf_read_color_attr(
+    const tinygltf::Model& model,
+    const std::map<std::string, int>& attributes,
+    const std::string& attr_name,
+    u32 expected_count) {
+  const auto it = attributes.find(attr_name);
+  if (it == attributes.end()) return {};
+  const auto& acc = model.accessors[it->second];
+  if ((u32)acc.count != expected_count) return {};
+  const auto& bv = model.bufferViews[acc.bufferView];
+  const auto& buf = model.buffers[bv.buffer];
+  const u8* data_ptr = buf.data.data() + bv.byteOffset + acc.byteOffset;
+  const u32 byte_stride = (u32)acc.ByteStride(bv);
+  const u32 count = (u32)acc.count;
+  switch (acc.type) {
+    case TINYGLTF_TYPE_VEC4:
+      switch (acc.componentType) {
+        case TINYGLTF_COMPONENT_TYPE_FLOAT:
+          return extract_color_from_vec4_float(data_ptr, count, byte_stride);
+        case TINYGLTF_COMPONENT_TYPE_UNSIGNED_SHORT:
+          return extract_color_from_vec4_u16(data_ptr, count, byte_stride);
+        case TINYGLTF_COMPONENT_TYPE_UNSIGNED_BYTE:
+          return extract_color_from_vec4_u8(data_ptr, count, byte_stride);
+        default:
+          lg::warn("gltf_read_color_attr: unknown component type for {}", attr_name);
+          return {};
+      }
+    case TINYGLTF_TYPE_VEC3:
+      if (acc.componentType == TINYGLTF_COMPONENT_TYPE_FLOAT)
+        return extract_color_from_vec3_float(data_ptr, count, byte_stride);
+      return {};
+    default:
+      return {};
+  }
+}
+


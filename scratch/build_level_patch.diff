# Patch for: goalc/build_level/jak1/build_level.cpp
# Adds "custom_tex_remap" JSON field support to the level build pipeline.
# This allows the addon to inject a custom texture remap table without
# copying it from an existing level BSP.
#
# Apply with: git apply build_level_patch.diff
# (from the jak-project root)
#
# Change summary: ~20 lines added, 0 lines changed, 0 lines removed.
# No structural changes. Uses the existing file.texture_remap_table field.
#
# Format of "custom_tex_remap" in level JSON:
#   "custom_tex_remap": [[orig_texid, new_texid], ...]
# Where:
#   orig_texid = (orig_page << 20) | (orig_index << 8)   -- bits[7:0] = 0
#   new_texid  = (new_page  << 20) | (new_index  << 8) | 0x14
# Table must be sorted by orig_texid (GOAL engine binary-searches it).
# Generated automatically by TpageCombiner.build() in the addon.

--- a/goalc/build_level/jak1/build_level.cpp
+++ b/goalc/build_level/jak1/build_level.cpp
@@ -132,6 +132,7 @@ bool run_build_level(const std::string& input_file,
   auto sky_name = level_json.value("sky", "none");
   auto texture_remap = level_json.value("tex_remap", "none");
   auto tpages = level_json.value("tpages", std::vector<u32>({}));
+  auto custom_tex_remap = level_json.value("custom_tex_remap", std::vector<std::vector<u32>>({}));

   // Add textures and models
   // TODO remove hardcoded config settings
@@ -336,6 +337,25 @@ bool run_build_level(const std::string& input_file,
     }
   }

+  // Apply custom texture remap table if provided directly in level JSON.
+  // "custom_tex_remap": [[orig_texid, new_texid], ...]
+  // Each pair: orig = (page << 20) | (index << 8), new = same | 0x14
+  // Table must be sorted by orig_texid (binary search in GOAL engine).
+  // This is generated by the OpenGOAL Blender addon's tpage combine pipeline
+  // and takes precedence over tex_remap (copy-from-level) if both present.
+  if (!custom_tex_remap.empty()) {
+    lg::info("custom level: applying custom_tex_remap with {} entries",
+             custom_tex_remap.size());
+    file.texture_remap_table.clear();
+    file.texture_remap_table.reserve(custom_tex_remap.size());
+    for (auto& pair : custom_tex_remap) {
+      if (pair.size() >= 2) {
+        file.texture_remap_table.push_back({pair[0], pair[1]});
+      }
+    }
+    // Set texture_ids from tpages if not already set by tex_remap path
+    if (!tpages.empty() && file.texture_ids.empty()) {
+      file.texture_ids.resize(tpages.size());
+      for (size_t i = 0; i < tpages.size(); ++i) {
+        file.texture_ids[i] = tpages[i] << 20;
+      }
+    }
+  }
+
   // Save the GOAL level
   auto result = file.save_object_file();
   lg::print("Level bsp file size {} bytes\n", result.size());
